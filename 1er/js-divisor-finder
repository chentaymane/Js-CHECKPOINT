function divisors(n) {
    var result = []
    if (n<0){
        n=-n
    }
    for (let i=0 ; i<n ; i++){
        if (n % i === 0 ){
            result.push(i)
        }
    }
    return result
}



console.log(divisors(15));
console.log(divisors(28));
console.log(divisors(1));
console.log(divisors(-15));

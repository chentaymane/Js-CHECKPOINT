function nestedArrayReverser(arr){
    let result = []
    if (arr.length === 0) {
        return []
    }
        for (let i=arr.length-1 ; i>= 0 ;i--){
            result.push(arr[i].join(" "))
            
            
        }
        return result.join(" ")
}
console.log(
  nestedArrayReverser([
    ["hello", "world"],
    ["this", "is"],
    ["a", "test"],
  ]),
);
  console.log(nestedArrayReverser([]))
